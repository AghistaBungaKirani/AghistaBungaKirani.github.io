  <script>
    (function() {
      // Ambil semua tombol dengan class 'run-btn'
      const buttons = document.querySelectorAll('.run-btn');

      // Fungsi untuk membuka popup yang berisi iframe ke URL DartPad
      function openPopupWithIframe(url) {
        // Hitung posisi dan ukuran popup (bisa disesuaikan)
        const width = 1000;
        const height = 700;
        const left = (window.screen.width / 2) - (width / 2);
        const top = (window.screen.height / 2) - (height / 2);

        // Buat konten HTML untuk popup: halaman sederhana berisi iframe penuh
        const popupContent = `
          <!DOCTYPE html>
          <html>
          <head>
            <meta charset="UTF-8">
            <title>DartPad - OOP</title>
            <style>
              body { margin: 0; padding: 0; overflow: hidden; background: #1e293b; }
              iframe { 
                width: 100vw; 
                height: 100vh; 
                border: none; 
                background: white;
              }
              .close-btn {
                position: fixed;
                top: 10px;
                right: 10px;
                z-index: 9999;
                background: #ef4444;
                color: white;
                border: none;
                border-radius: 30px;
                padding: 8px 18px;
                font-weight: bold;
                cursor: pointer;
                box-shadow: 0 4px 10px rgba(0,0,0,0.3);
                font-size: 14px;
              }
              .close-btn:hover { background: #dc2626; }
            </style>
          </head>
          <body>
            <button class="close-btn" onclick="window.close()">✕ Tutup Popup</button>
            <iframe src="${url}?embed=true" title="DartPad OOP"></iframe>
          </body>
          </html>
        `;

        // Buka popup dengan spesifikasi
        const popup = window.open(
          '', 
          '_blank', 
          `width=${width},height=${height},left=${left},top=${top},resizable=yes,scrollbars=yes,status=yes`
        );

        if (popup) {
          // Tulis konten HTML ke popup
          popup.document.write(popupContent);
          popup.document.close(); // selesaikan penulisan
          popup.focus();
        } else {
          alert('Popup terblokir. Izinkan popup untuk situs ini agar dapat melihat program.');
        }
      }

      // Tambahkan event listener ke setiap tombol
      buttons.forEach(btn => {
        btn.addEventListener('click', function(e) {
          const url = this.getAttribute('data-url');
          if (url) {
            openPopupWithIframe(url);
          } else {
            alert('URL program tidak ditemukan.');
          }
        });
      });
    })();
  </script>

  <!-- Penjelasan: 
       Setiap kotak sekarang tidak memuat iframe langsung, tetapi tombol.
       Saat tombol diklik, kita buka popup berisi iframe yang menunjuk ke URL DartPad.
       Hal ini memenuhi permintaan: "iframe harus di klik button dulu baru dia kebuka popup".
